<?xml version="1.0" encoding="utf-8" ?>

<ContentPage
    x:Class="Docs_Manager.View.AddVisaPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Visa"
    BackgroundColor="#071a2d">

    <ScrollView>

        <VerticalStackLayout
            Padding="20"
            Spacing="15">

            <Grid ColumnDefinitions="*,Auto">

                <Label
        Text="🛂 Visa"
        FontSize="24"
        FontAttributes="Bold"
        TextColor="#ff9933"
        VerticalOptions="Center"/>

                <Button
        Grid.Column="1"
        Text="✕"
        WidthRequest="40"
        HeightRequest="40"
        CornerRadius="20"
        BackgroundColor="#ff4d6d"
        TextColor="White"
        Clicked="OnCloseClicked"/>

            </Grid>

            <Button
    Text="+ Add Visa"
    Clicked="OnAddVisaClicked"
    BackgroundColor="#19b5ea"
    TextColor="White" />

            <VerticalStackLayout
    x:Name="VisaContainer"
    Spacing="10" />

            <Button
    Text="SAVE"
    HeightRequest="45"
    FontAttributes="Bold"
    BackgroundColor="#22c55e"
    TextColor="White"
    Clicked="OnSaveClicked" />
           




        </VerticalStackLayout>

    </ScrollView>

</ContentPage>