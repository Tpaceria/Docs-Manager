<?xml version="1.0" encoding="utf-8" ?>

<ContentView
    x:Class="Docs_Manager.Controls.DateSelector"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <HorizontalStackLayout
        Spacing="8">

        <Picker
            x:Name="DayPicker"
            WidthRequest="70"
            Title="DD" />

        <Picker
            x:Name="MonthPicker"
            WidthRequest="70"
            Title="MM" />

        <Picker
            x:Name="YearPicker"
            WidthRequest="100"
            Title="YYYY" />

    </HorizontalStackLayout>

</ContentView>