<ContentPage
    x:Class="Docs_Manager.MainPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Documents">

    <Grid RowDefinitions="Auto, *">

        <Button 
            Text="+ Add Document"
            Clicked="OnAddDocumentClicked"
            Margin="10"
            HorizontalOptions="End" />

        <CollectionView 
            Grid.Row="1"
            Margin="10"
            ItemsSource="{Binding Documents}">

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border 
                        Padding="10" 
                        Margin="5"
                        Stroke="#444"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 8">

                        <VerticalStackLayout Spacing="4">

                            <Label Text="{Binding Title}"
                                   FontAttributes="Bold"
                                   FontSize="18"/>

                            <Label Text="{Binding Type}" />

                            <Label Text="{Binding ExpiryDate, StringFormat='Expiry: {0:dd.MM.yyyy}'}" />

                            <Label Text="{Binding DaysLeft, StringFormat='Days left: {0}'}"
                                   TextColor="Orange"/>

                        </VerticalStackLayout>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>

        </CollectionView>

    </Grid>
</ContentPage>