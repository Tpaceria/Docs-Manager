<?xml version="1.0" encoding="utf-8" ?>

<ContentView
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="Docs_Manager.View.FilesPage">

    <VerticalStackLayout Padding="20" Spacing="12">

        <Button
            Text="Certificates"
            Clicked="OnCertificatesClicked"/>

        <Button
            Text="COC"
            Clicked="OnCocClicked"/>

        <Button
            Text="Documents"
            Clicked="OnDocumentsClicked"/>

        <Button
            Text="Medicine"
            Clicked="OnMedicineClicked"/>

        <Button
            Text="Other"
            Clicked="OnOtherClicked"/>

    </VerticalStackLayout>

</ContentView>