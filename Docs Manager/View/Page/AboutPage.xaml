<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Docs_Manager.View.AboutPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="О себе">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="16">

            <Label Text="О себе"
                   FontSize="20"
                   FontAttributes="Bold"/>

            <Editor
                Placeholder="Введите описание профессиональных навыков..."
                AutoSize="TextChanges"
                HeightRequest="150" />

            <Button
                Text="Сохранить"
                HeightRequest="50"/>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>