<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Docs_Manager.View.FilesPage"
             Title="Files">

    <Grid RowDefinitions="Auto,Auto,*" Padding="0">

        <!-- Add Button -->
     
        <Button Grid.Row="0"
        x:Name="AddButton"
        Text="+ Add Certificate"
        BackgroundColor="Transparent"
        TextColor="#0099CC"
        FontSize="14"
        Clicked="OnAddFileClicked"
        Margin="10,10,0,10"
        HorizontalOptions="Start"/>

        <!-- Tabs/Categories Header -->
        <HorizontalStackLayout Grid.Row="1" Padding="10,0" Spacing="0">
            <Button Text="CERTIFICATES" 
                    Clicked="OnCategoryButtonClicked"
                    BackgroundColor="Transparent"
                    TextColor="#0099CC"
                    FontAttributes="Bold"
                    Padding="15,10"
                    HorizontalOptions="Start"/>

            <Button Text="COC &amp; ENDORSEMENT" 
                    Clicked="OnCategoryButtonClicked"
                    BackgroundColor="Transparent"
                    TextColor="#666666"
                    Padding="15,10"
                    HorizontalOptions="Start"/>

            <Button Text="DOCUMENTS" 
                    Clicked="OnCategoryButtonClicked"
                    BackgroundColor="Transparent"
                    TextColor="#666666"
                    Padding="15,10"
                    HorizontalOptions="Start"/>

            <Button Text="MEDICINE" 
                    Clicked="OnCategoryButtonClicked"
                    BackgroundColor="Transparent"
                    TextColor="#666666"
                    Padding="15,10"
                    HorizontalOptions="Start"/>

            <Button Text="OTHER" 
                    Clicked="OnCategoryButtonClicked"
                    BackgroundColor="Transparent"
                    TextColor="#666666"
                    Padding="15,10"
                    HorizontalOptions="Start"/>
        </HorizontalStackLayout>

        <!-- Content Area -->
        <CollectionView Grid.Row="2" x:Name="FilesCollection">
            <CollectionView.ItemsLayout>
                <LinearItemsLayout Orientation="Vertical" ItemSpacing="10"/>
            </CollectionView.ItemsLayout>
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <StackLayout Padding="20,10" Spacing="8" BackgroundColor="#F9F9F9" Margin="10,0">
                        <Label Text="{Binding FileName}" FontSize="16" FontAttributes="Bold" TextColor="#333333"/>
                        <Label Text="{Binding Category, StringFormat='Category: {0}'}" FontSize="12" TextColor="#666666"/>
                        <Label Text="{Binding UploadDate, StringFormat='Uploaded: {0:dd.MM.yyyy}'}" FontSize="12" TextColor="#999999"/>

                        <StackLayout Orientation="Horizontal" Spacing="10">
                            <Label Text="Download" TextColor="#0066CC" FontSize="12">
                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer CommandParameter="{Binding .}" Tapped="OnDownloadFile"/>
                                </Label.GestureRecognizers>
                            </Label>
                            <Label Text="Delete" TextColor="#CC0000" FontSize="12">
                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer CommandParameter="{Binding .}" Tapped="OnDeleteFile"/>
                                </Label.GestureRecognizers>
                            </Label>
                        </StackLayout>
                    </StackLayout>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </Grid>

</ContentPage>