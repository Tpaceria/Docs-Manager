<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Docs_Manager.View.FilesPage"
             Title="Files">

    <VerticalStackLayout Padding="0" Spacing="0">

        <!-- Header -->
        <VerticalStackLayout Padding="20" Spacing="10" BackgroundColor="#1a1a1a">
            <StackLayout Orientation="Horizontal" Spacing="10">
                <Label Text="📁" FontSize="28"/>
                <Label Text="FILES &amp; CERTIFICATES" 
                       FontSize="22" 
                       FontAttributes="Bold"
                       TextColor="#FF6B35"
                       VerticalOptions="Center"/>
            </StackLayout>
            <Label Text="Select a category to manage your certificates"
                   FontSize="13"
                   TextColor="#AAAAAA"/>
        </VerticalStackLayout>

        <!-- Category Buttons -->
        <VerticalStackLayout Padding="20" Spacing="12">

            <Button Text="📄 CERTIFICATES"
                    BackgroundColor="#FF6B35"
                    TextColor="White"
                    FontSize="14"
                    FontAttributes="Bold"
                    Clicked="OnCertificatesClicked"
                    HeightRequest="50"
                    CornerRadius="8"/>

            <Button Text="📜 COC &amp; ENDORSEMENT"
                    BackgroundColor="#0099CC"
                    TextColor="White"
                    FontSize="14"
                    FontAttributes="Bold"
                    Clicked="OnCocClicked"
                    HeightRequest="50"
                    CornerRadius="8"/>

            <Button Text="📄 DOCUMENTS"
                    BackgroundColor="#28A745"
                    TextColor="White"
                    FontSize="14"
                    FontAttributes="Bold"
                    Clicked="OnDocumentsClicked"
                    HeightRequest="50"
                    CornerRadius="8"/>

            <Button Text="🏥 MEDICINE"
                    BackgroundColor="#DC3545"
                    TextColor="White"
                    FontSize="14"
                    FontAttributes="Bold"
                    Clicked="OnMedicineClicked"
                    HeightRequest="50"
                    CornerRadius="8"/>

            <Button Text="📋 OTHER"
                    BackgroundColor="#6C757D"
                    TextColor="White"
                    FontSize="14"
                    FontAttributes="Bold"
                    Clicked="OnOtherClicked"
                    HeightRequest="50"
                    CornerRadius="8"/>

        </VerticalStackLayout>

    </VerticalStackLayout>

</ContentPage>