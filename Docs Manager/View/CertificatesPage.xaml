<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Docs_Manager.View.CertificatesPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Сертификаты">

    <Grid RowDefinitions="Auto, *">

        <Button
            Text="+ Добавить сертификат"
            Clicked="OnAddClicked"
            Margin="10"
            HorizontalOptions="End"/>

        <CollectionView
            Grid.Row="1"
            Margin="10"
            ItemsSource="{Binding Certificates}">

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Grid>

                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer
                                Tapped="OnItemTapped"
                                CommandParameter="{Binding .}" />
                        </Grid.GestureRecognizers>

                        <Border Margin="6"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 14"
                                BackgroundColor="#1E1E1E">

                            <VerticalStackLayout Padding="16" Spacing="6">

                                <Label Text="{Binding Name}"
                                       FontSize="18"
                                       FontAttributes="Bold"/>

                                <Label Text="{Binding Number}" />

                                <Label Text="{Binding ExpiryDate, StringFormat='Истекает: {0:dd.MM.yyyy}'}" />

                                <Label Text="{Binding StatusText}"
                                       TextColor="{Binding StatusColor}"
                                       FontAttributes="Bold"/>

                            </VerticalStackLayout>

                        </Border>

                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>

        </CollectionView>

    </Grid>
</ContentPage>