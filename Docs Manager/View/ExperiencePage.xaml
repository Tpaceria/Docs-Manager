<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Docs_Manager.View.ExperiencePage"
             Title="Experience"
             BackgroundColor="#0a1628"
             Padding="0">

    <Grid RowDefinitions="Auto,*" Padding="0" RowSpacing="0">

        <!-- ADD BUTTON - FIXED AT TOP -->
        <Button Grid.Row="0"
                Text="➕ Add Experience"
                HeightRequest="60"
                BackgroundColor="#0099CC"
                TextColor="White"
                FontSize="16"
                FontAttributes="Bold"
                Clicked="OnAddClicked"
                Margin="20,10,20,10"
                CornerRadius="8"/>

        <!-- LIST - SCROLLABLE -->
        <CollectionView Grid.Row="1"
                        x:Name="ExperienceCollectionView"
                        SelectionMode="Single"
                        Margin="0"
                        EmptyView="No experiences">
            <CollectionView.ItemsLayout>
                <LinearItemsLayout Orientation="Vertical" ItemSpacing="12"/>
            </CollectionView.ItemsLayout>
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border StrokeShape="RoundRectangle 8"
                            Stroke="#333333"
                            StrokeThickness="1"
                            Padding="0"
                            BackgroundColor="#2a2a2a"
                            Margin="12,6,12,6">

                        <Grid ColumnDefinitions="Auto,*,Auto,Auto" 
                              ColumnSpacing="12" 
                              Padding="16,12,16,12"
                              VerticalOptions="Center">

                            <!-- Vessel Name and Position -->
                            <VerticalStackLayout Grid.Column="0" Spacing="3" WidthRequest="150">
                                <Label Text="{Binding VesselName}"
                                       FontSize="14"
                                       FontAttributes="Bold"
                                       TextColor="#FFFFFF"
                                       LineBreakMode="TailTruncation"/>
                                <Label Text="{Binding Position}"
                                       FontSize="12"
                                       TextColor="#FF6B35"
                                       FontAttributes="Bold"/>
                            </VerticalStackLayout>

                            <!-- Dates -->
                            <StackLayout Grid.Column="1" 
                                        Orientation="Horizontal" 
                                        Spacing="20"
                                        HorizontalOptions="FillAndExpand">
                                <VerticalStackLayout Spacing="2">
                                    <Label Text="From:"
                                           FontSize="10"
                                           TextColor="#888888"/>
                                    <Label Text="{Binding SignOnDate, StringFormat='{0:dd.MM.yyyy}'}"
                                           FontSize="11"
                                           TextColor="#FFFFFF"
                                           FontAttributes="Bold"/>
                                </VerticalStackLayout>
                                <VerticalStackLayout Spacing="2">
                                    <Label Text="To:"
                                           FontSize="10"
                                           TextColor="#888888"/>
                                    <Label Text="{Binding SignOffDate, StringFormat='{0:dd.MM.yyyy}'}"
                                           FontSize="11"
                                           TextColor="#FFFFFF"
                                           FontAttributes="Bold"/>
                                </VerticalStackLayout>
                            </StackLayout>

                            <!-- Edit Button -->
                            <FlexLayout Grid.Column="1"
            Direction="Row"
            Wrap="Wrap"
            AlignItems="Center"
            JustifyContent="End">

                                <Button Text="Edit"
            BackgroundColor="#FFC107"
            TextColor="Black"
            CornerRadius="10"
            Padding="12,6"
            Margin="0,0,10,0"
            FontSize="12"
            Clicked="OnEditClicked"
            CommandParameter="{Binding .}" />

                                <Button Text="Delete"
            BackgroundColor="#DC3545"
            TextColor="White"
            CornerRadius="10"
            Padding="12,6"
            FontSize="12"
            Clicked="OnDeleteClicked"
            CommandParameter="{Binding .}" />

                            </FlexLayout>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </Grid>

</ContentPage>