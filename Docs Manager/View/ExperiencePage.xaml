<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Docs_Manager.View.ExperiencePage"
             Title="Experience">

    <VerticalStackLayout Padding="20" Spacing="15">

        <!-- Header -->
        <StackLayout Orientation="Horizontal" Spacing="10">
            <Label Text="🚢" FontSize="28"/>
            <Label Text="EXPERIENCE" FontSize="24" FontAttributes="Bold" TextColor="#FF6B35"/>
        </StackLayout>

        <!-- Info Text -->
        <Label Text="Add your previous sea service. Companies prefer profiles with extensive sea-going experience." 
               FontSize="14" TextColor="#666666"/>

        <!-- Separator -->
        <BoxView HeightRequest="1" Color="#E0E0E0" Margin="0,10"/>

        <!-- Experience List -->
        <CollectionView x:Name="ExperienceCollectionView" SelectionMode="Single">
            <CollectionView.ItemsLayout>
                <LinearItemsLayout Orientation="Vertical" ItemSpacing="15"/>
            </CollectionView.ItemsLayout>
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <StackLayout Padding="0,10" Spacing="8">
                        <Label Text="{Binding DateRange}" FontSize="16" FontAttributes="Bold" TextColor="#333333"/>

                        <StackLayout Orientation="Horizontal" Spacing="10">
                            <Label Text="Edit" TextColor="#0066CC" FontSize="14">
                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer CommandParameter="{Binding .}" Tapped="OnEditExperienceClicked"/>
                                </Label.GestureRecognizers>
                            </Label>
                            <Label Text="Delete" TextColor="#CC0000" FontSize="14">
                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer CommandParameter="{Binding .}" Tapped="OnDeleteExperienceClicked"/>
                                </Label.GestureRecognizers>
                            </Label>
                        </StackLayout>

                        <BoxView HeightRequest="1" Color="#E0E0E0"/>
                    </StackLayout>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- Add Button -->
        <Button Text="+ Add the Trip" 
                BackgroundColor="Transparent"
                TextColor="#0099CC"
                FontSize="16"
                Clicked="OnAddExperienceClicked"
                Margin="0,20,0,0"/>

    </VerticalStackLayout>

</ContentPage>