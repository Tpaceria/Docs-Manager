<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Docs_Manager.View.MedicinePage"
             Title="Medicine"
             BackgroundColor="#0a1628"
             Padding="0">

    <Grid RowDefinitions="Auto,*" Padding="0" RowSpacing="0">

        <!-- ADD BUTTON - FIXED AT TOP -->
        <Button Grid.Row="0"
                Text="➕ Add Medicine"
                HeightRequest="60"
                BackgroundColor="#0099CC"
                TextColor="White"
                FontSize="16"
                FontAttributes="Bold"
                Clicked="OnAddCertificateClicked"
                Margin="20,10,20,10"
                CornerRadius="8"/>

        <!-- LIST - SCROLLABLE -->
        <CollectionView Grid.Row="1"
                        x:Name="CertificateCollectionView"
                        SelectionMode="Single"
                        Margin="0"
                        EmptyView="No medicines">
            <CollectionView.ItemsLayout>
                <LinearItemsLayout Orientation="Vertical" ItemSpacing="12"/>
            </CollectionView.ItemsLayout>
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border StrokeShape="RoundRectangle 8"
                            Stroke="#333333"
                            StrokeThickness="1"
                            Padding="0"
                            BackgroundColor="#2a2a2a"
                            Margin="12,6,12,6">

                        <Grid ColumnDefinitions="*,Auto,Auto" 
                              ColumnSpacing="12" 
                              Padding="16,12,16,12"
                              VerticalOptions="Center">

                            <Label Grid.Column="0"
                                   Text="{Binding Document}"
                                   FontSize="14"
                                   FontAttributes="Bold"
                                   TextColor="#FFFFFF"/>

                            <Button Grid.Column="1"
                                    Text="✏️"
                                    BackgroundColor="#0099CC"
                                    TextColor="White"
                                    Padding="8"
                                    Clicked="OnEditCertificateClicked"
                                    CommandParameter="{Binding .}"
                                    WidthRequest="38"
                                    HeightRequest="38"
                                    CornerRadius="6"/>

                            <Button Grid.Column="2"
                                    Text="🗑️"
                                    BackgroundColor="#DC3545"
                                    TextColor="White"
                                    Padding="8"
                                    Clicked="OnDeleteCertificateClicked"
                                    CommandParameter="{Binding .}"
                                    WidthRequest="38"
                                    HeightRequest="38"
                                    CornerRadius="6"/>

                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </Grid>

</ContentPage>