<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Docs_Manager.View.CocEndorsementPage"
             Title="COC and Endorsement"
             BackgroundColor="#0a1628"
             Padding="0">

    <Grid RowDefinitions="Auto,*" Padding="0" RowSpacing="0">

        <!-- ADD BUTTON - FIXED AT TOP -->
        <Button Grid.Row="0"
                Text="➕ Add COC"
                HeightRequest="60"
                BackgroundColor="#0099CC"
                TextColor="White"
                FontSize="16"
                FontAttributes="Bold"
                Clicked="OnAddCertificateClicked"
                Margin="20,10,20,10"
                CornerRadius="8"/>

        <!-- LIST - SCROLLABLE -->
        <CollectionView Grid.Row="1"
                        x:Name="CertificateCollectionView"
                        SelectionMode="Single"
                        Margin="0"
                        EmptyView="No COCs">
            <CollectionView.ItemsLayout>
                <LinearItemsLayout Orientation="Vertical" ItemSpacing="12"/>
            </CollectionView.ItemsLayout>
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border StrokeShape="RoundRectangle 8"
                            Stroke="#333333"
                            StrokeThickness="1"
                            Padding="0"
                            BackgroundColor="#2a2a2a"
                            Margin="12,6,12,6">

                        <Grid ColumnDefinitions="*,Auto,Auto" 
                              ColumnSpacing="12" 
                              Padding="16,12,16,12"
                              VerticalOptions="Center">

                            <Label Grid.Column="0"
                                   Text="{Binding Document}"
                                   FontSize="14"
                                   FontAttributes="Bold"
                                   TextColor="#FFFFFF"/>

                            <FlexLayout Grid.Column="1"
            Grid.ColumnSpan="2"
            Direction="Row"
            Wrap="Wrap"
            AlignItems="Center"
            JustifyContent="End">

                                <!-- VIEW -->
                                <Button Text="View"
            BackgroundColor="#00d4ff"
            TextColor="White"
            CornerRadius="10"
            Padding="12,6"
            Margin="0,0,10,0"
            FontSize="12"
            Clicked="OnViewCertificateClicked"
            CommandParameter="{Binding .}" />

                                <!-- EDIT -->
                                <Button Text="Edit"
            BackgroundColor="#FFC107"
            TextColor="Black"
            CornerRadius="10"
            Padding="12,6"
            Margin="0,0,10,0"
            FontSize="12"
            Clicked="OnEditCertificateClicked"
            CommandParameter="{Binding .}" />

                                <!-- DELETE -->
                                <Button Text="Delete"
            BackgroundColor="#DC3545"
            TextColor="White"
            CornerRadius="10"
            Padding="12,6"
            FontSize="12"
            Clicked="OnDeleteCertificateClicked"
            CommandParameter="{Binding .}" />

                            </FlexLayout>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </Grid>

</ContentPage>