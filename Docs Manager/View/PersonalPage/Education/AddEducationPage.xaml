<?xml version="1.0" encoding="utf-8" ?>

<ContentPage
    x:Class="Docs_Manager.View.AddEducationPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:controls="clr-namespace:Docs_Manager.Controls"
    BackgroundColor="#071a2f"
    Title="Education">
    
    <ScrollView>

        <VerticalStackLayout
            Padding="20"
            Spacing="16">

            <!-- HEADER -->

            <Grid ColumnDefinitions="*,Auto">

                <Label
                    Text="🎓 Education"
                    FontSize="24"
                    FontAttributes="Bold"
                    TextColor="#00d4ff"/>

                <Button
                    Grid.Column="1"
                    Text="✕"
                    WidthRequest="40"
                    HeightRequest="40"
                    CornerRadius="20"
                    BackgroundColor="#ff4d6d"
                    TextColor="White"
                    Clicked="OnCloseClicked"/>

            </Grid>

            <!-- EDUCATION BLOCK -->

            <Border
                BackgroundColor="#102844"
                Stroke="#173b63"
                StrokeShape="RoundRectangle 14"
                Padding="14">

                <VerticalStackLayout Spacing="14">

                    <!-- ADD BUTTON -->

                    <Button
    HorizontalOptions="Center"
    Text="+"
    WidthRequest="40"
    HeightRequest="40"
    CornerRadius="20"
    BackgroundColor="#19b5ea"
    TextColor="White"
    FontAttributes="Bold"
    Clicked="OnAddEducationClicked"/>
                    <!-- CONTAINER -->

                    <VerticalStackLayout
                        x:Name="EducationContainer"
                        Spacing="14"/>

                </VerticalStackLayout>

            </Border>

            <!-- SAVE -->

            <Button
                Text="💾 Save Education"
                HeightRequest="52"
                CornerRadius="12"
                BackgroundColor="#28a745"
                TextColor="White"
                FontAttributes="Bold"
                Clicked="OnSaveClicked"/>

        </VerticalStackLayout>

    </ScrollView>

</ContentPage>