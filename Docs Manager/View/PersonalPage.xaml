<?xml version="1.0" encoding="utf-8" ?>

<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="Docs_Manager.View.PersonalPage"
    BackgroundColor="{StaticResource PageBackground}"
    Padding="0">

    <Grid RowDefinitions="Auto,*">

        <!-- ===================================== -->
        <!-- HEADER -->
        <!-- ===================================== -->

        <Border Grid.Row="0"
                BackgroundColor="#0d1b2d"
                StrokeThickness="0"
                Padding="24,18">

            <Grid ColumnDefinitions="*,Auto,Auto"
                  ColumnSpacing="12">

                <VerticalStackLayout Spacing="2">

                    <Label Text="Personal Dashboard"
                           FontSize="28"
                           FontAttributes="Bold"
                           TextColor="White"/>

                    <Label Text="Manage personal seafarer information"
                           FontSize="13"
                           TextColor="#7f9bb8"/>

                </VerticalStackLayout>

                <Button Grid.Column="1"
                        Text="💾 Save"
                        BackgroundColor="#28A745"
                        TextColor="White"
                        WidthRequest="140"
                        Clicked="OnSaveClicked"/>

                <Button Grid.Column="2"
                        Text="✖ Cancel"
                        BackgroundColor="#ff4d6d"
                        TextColor="White"
                        WidthRequest="140"
                        Clicked="OnCancelClicked"/>

            </Grid>

        </Border>

        <!-- ===================================== -->
        <!-- CONTENT -->
        <!-- ===================================== -->

        <ScrollView Grid.Row="1">

            <Grid Padding="20"
                  ColumnDefinitions="2*,1*"
                  ColumnSpacing="18">

                <!-- ===================================== -->
                <!-- LEFT COLUMN -->
                <!-- ===================================== -->

                <VerticalStackLayout Spacing="18">

                    <!-- BASIC -->

                    <Label Text="📋 BASIC INFORMATION"
                           Style="{StaticResource SectionTitleStyle}"/>

                    <Border Style="{StaticResource DashboardCardStyle}">

                        <VerticalStackLayout>

                            <Entry x:Name="FirstNameEntry"
                                   Placeholder="First Name"/>

                            <Entry x:Name="LastNameEntry"
                                   Placeholder="Last Name"/>

                            <Entry x:Name="EmailEntry"
                                   Placeholder="Email"
                                   Keyboard="Email"/>

                            <Entry x:Name="PhoneEntry"
                                   Placeholder="Phone"
                                   Keyboard="Telephone"/>

                            <Label Text="Birth Date"
                                   TextColor="White"
                                   Margin="0,10,0,4"/>

                            <DatePicker x:Name="BirthDatePicker"
                                        BackgroundColor="#1a1f2e"
                                        TextColor="White"/>

                        </VerticalStackLayout>

                    </Border>

                    <!-- PROFESSIONAL -->

                    <Label Text="💼 PROFESSIONAL"
                           Style="{StaticResource SectionTitleStyle}"/>

                    <Border Style="{StaticResource DashboardCardStyle}">

                        <VerticalStackLayout>

                            <Entry x:Name="PositionEntry"
                                   Placeholder="Position"/>

                            <Entry x:Name="CitizenshipEntry"
                                   Placeholder="Citizenship"/>

                            <Entry x:Name="ResidenceEntry"
                                   Placeholder="Residence"/>

                            <Entry x:Name="ResidenceAirportEntry"
                                   Placeholder="Nearest Airport"/>

                            <Entry x:Name="DesiredWageEntry"
                                   Placeholder="Desired Wage"
                                   Keyboard="Numeric"/>

                        </VerticalStackLayout>

                    </Border>

                </VerticalStackLayout>

                <!-- ===================================== -->
                <!-- RIGHT COLUMN -->
                <!-- ===================================== -->

                <VerticalStackLayout Grid.Column="1"
                                     Spacing="18">

                    <!-- PHOTO -->

                    <Label Text="📸 PHOTO"
                           Style="{StaticResource SectionTitleStyle}"/>

                    <Border Style="{StaticResource DashboardCardStyle}">

                        <VerticalStackLayout Spacing="14">

                            <Image x:Name="PhotoImage"
                                   HeightRequest="220"
                                   WidthRequest="220"
                                   Aspect="AspectFill"
                                   HorizontalOptions="Center"/>

                            <Button x:Name="PickPhotoButton"
                                    Text="Choose Photo"
                                    BackgroundColor="#00bfff"
                                    TextColor="White"
                                    Clicked="OnPickPhotoClicked"/>

                        </VerticalStackLayout>

                    </Border>

                    <!-- PERSONAL -->

                    <Label Text="👤 PERSONAL"
                           Style="{StaticResource SectionTitleStyle}"/>

                    <Border Style="{StaticResource DashboardCardStyle}">

                        <VerticalStackLayout>

                            <Entry x:Name="HeightEntry"
                                   Placeholder="Height (cm)"
                                   Keyboard="Numeric"/>

                            <Entry x:Name="WeightEntry"
                                   Placeholder="Weight (kg)"
                                   Keyboard="Numeric"/>

                            <Entry x:Name="ShoeSizeEntry"
                                   Placeholder="Shoe Size"
                                   Keyboard="Numeric"/>

                            <Entry x:Name="OverallSizeEntry"
                                   Placeholder="Overall Size"
                                   Keyboard="Numeric"/>

                            <Entry x:Name="HairColorEntry"
                                   Placeholder="Hair Color"/>

                            <Entry x:Name="EyeColorEntry"
                                   Placeholder="Eye Color"/>

                        </VerticalStackLayout>

                    </Border>

                    <!-- EDUCATION -->

                    <Label Text="🎓 EDUCATION"
                           Style="{StaticResource SectionTitleStyle}"/>

                    <Border Style="{StaticResource DashboardCardStyle}">

                        <VerticalStackLayout>

                            <Entry x:Name="QualificationEntry"
                                   Placeholder="Qualification"/>

                            <Entry x:Name="EducationInstitutionEntry"
                                   Placeholder="Institution"/>

                            <Label Text="Graduation Date"
                                   TextColor="White"
                                   Margin="0,10,0,4"/>

                            <DatePicker x:Name="GraduationDatePicker"
                                        BackgroundColor="#1a1f2e"
                                        TextColor="White"/>

                        </VerticalStackLayout>

                    </Border>

                </VerticalStackLayout>

            </Grid>

        </ScrollView>

    </Grid>

</ContentPage>