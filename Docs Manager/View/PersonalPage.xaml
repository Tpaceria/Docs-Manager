<?xml version="1.0" encoding="utf-8" ?>

<ContentView
    x:Class="Docs_Manager.View.PersonalPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    BackgroundColor="#071a2f">

    <ScrollView>

        <Grid
            Padding="10"
            ColumnSpacing="10">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2.2*" />
                <ColumnDefinition Width="1*" />
            </Grid.ColumnDefinitions>

            <!-- ===================================== -->
            <!-- LEFT COLUMN -->
            <!-- ===================================== -->

            <VerticalStackLayout
    Grid.Column="0"
    Spacing="10">

                <!-- HEADER -->

                <Border
    BackgroundColor="#102844"
    Stroke="#173b63"
    StrokeShape="RoundRectangle 10"
    Padding="8">

        <Grid

            ColumnDefinitions="130,4.2*,2.8*"
            ColumnSpacing="12">
                        <!-- PHOTO -->

                        <VerticalStackLayout
            Grid.Column="0"
            Spacing="6">

                            <Frame
                WidthRequest="110"
                HeightRequest="140"
                Padding="0"
                CornerRadius="8"
                BackgroundColor="#1a2238"
                BorderColor="#2d4d73"
                HasShadow="False">

                                <Image
                    x:Name="PhotoImage"
                    Aspect="AspectFill"/>

                            </Frame>

                            <Button
                x:Name="PickPhotoButton"
                Text="Choose Photo"
                HeightRequest="28"
                CornerRadius="6"
                FontSize="11"
                BackgroundColor="#19b5ea"
                TextColor="White"
                Clicked="OnPickPhotoClicked"/>

                            <Button
    x:Name="SaveButton"
    Text="💾 SAVE PROFILE"
    HeightRequest="28"
    CornerRadius="6"
    FontSize="11"
    BackgroundColor="#28a745"
    TextColor="White"
    FontAttributes="Bold"
    Clicked="OnSaveClicked"/>

                        </VerticalStackLayout>

                        <!-- PROFILE -->

                        <Grid
    Grid.Column="1"
    ColumnDefinitions="*,*"
    RowDefinitions="Auto,Auto,Auto,Auto"
    ColumnSpacing="20"
    RowSpacing="1">

                            <VerticalStackLayout
        Grid.Row="0"
        Grid.Column="0"
        Spacing="2">

                                <Label
            Text="First Name"
            FontSize="12"
            TextColor="White"/>

                                <Entry
            x:Name="FirstNameEntry"
            HeightRequest="30"
            FontSize="16"/>                    
                            </VerticalStackLayout>

                            <VerticalStackLayout
        Grid.Row="0"
        Grid.Column="1"
        Spacing="2">

                                <Label
            Text="Nationality"
            FontSize="12"
            TextColor="White"/>

                                <Entry
            x:Name="NationalityEntry"
            HeightRequest="30"
            FontSize="16"/>
                            </VerticalStackLayout>

                            <VerticalStackLayout
        Grid.Row="1"
        Grid.Column="0"
        Spacing="2">

                                <Label
            Text="Middle Name"
            FontSize="12"
            TextColor="White"/>

                                <Entry
            x:Name="MiddleNameEntry"
            HeightRequest="30"
            FontSize="16"/>
                            </VerticalStackLayout>

                            <VerticalStackLayout
        Grid.Row="1"
        Grid.Column="1"
        Spacing="2">

                                <Label
            Text="Place of Birth"
            FontSize="12"
            TextColor="White"/>

                                <Entry
            x:Name="PlaceOfBirthEntry"
            HeightRequest="30"
            FontSize="16"/>
                            </VerticalStackLayout>

                            <VerticalStackLayout
        Grid.Row="2"
        Grid.Column="0"
        Spacing="2">

                                <Label
            Text="Last Name"
            FontSize="12"
            TextColor="White"/>

                                <Entry
            x:Name="LastNameEntry"
            HeightRequest="30"
            FontSize="16"/>
                            </VerticalStackLayout>

                            <VerticalStackLayout
        Grid.Row="2"
        Grid.Column="1"
        Spacing="2">

                                <Label
            Text="Citizenship"
            FontSize="12"
            TextColor="White"/>

                                <Entry
            x:Name="CitizenshipEntry"
            HeightRequest="30"
            FontSize="16"/>
                            </VerticalStackLayout>

                            <VerticalStackLayout
        Grid.Row="3"
        Grid.Column="0"
        Spacing="2">

                                <Label
            Text="Date of Birth"
            FontSize="12"
            TextColor="White"/>

                                <DatePicker
            x:Name="BirthDatePicker"
            HeightRequest="30"
            FontSize="16"/>
                            </VerticalStackLayout>

                            <VerticalStackLayout
        Grid.Row="3"
        Grid.Column="1"
        Spacing="2">

                                <Label
            Text="Gender"
            FontSize="12"
            TextColor="White"/>

                                <Picker
            x:Name="GenderPicker"
            HeightRequest="30"
            FontSize="16"/>
                            </VerticalStackLayout>

                        </Grid>

                    </Grid>

                </Border>

                <!-- EDUCATION -->

                <Border
    BackgroundColor="#102844"
    Stroke="#173b63"
    StrokeShape="RoundRectangle 10"
    Padding="8">

                    <VerticalStackLayout Spacing="8">

                        <Grid ColumnDefinitions="*,Auto">

                            <Label
                Text="🎓 EDUCATION"
                FontSize="16"
                FontAttributes="Bold"
                TextColor="#ff8c42"/>

<Button
    Grid.Column="1"
    Text="Edit"
    HeightRequest="28"
    WidthRequest="60"
    CornerRadius="6"
    FontSize="12"
    BackgroundColor="#19b5ea"
    TextColor="White"
    Clicked="OnEditEducationClicked"/>
                        </Grid>

                        <VerticalStackLayout
            x:Name="EducationPreviewContainer"
            Spacing="6"/>

                    </VerticalStackLayout>

                </Border>
                <!-- COC TABLE -->

                <Border
        BackgroundColor="#102844"
        Stroke="#173b63"
        StrokeShape="RoundRectangle 10"
        Padding="8">

                    <VerticalStackLayout
            Spacing="6">

                        <Label
                Text="📘 COC"
                FontSize="16"
                FontAttributes="Bold"
                TextColor="#ff8c42"/>

                        <!-- TABLE HEADER -->

                        <Grid
                ColumnDefinitions="3*,2*,2*"
                Padding="0,0,0,4">

                            <Label
                    Text="Document"
                    FontAttributes="Bold"
                    TextColor="#19b5ea"/>

                            <Label
                    Grid.Column="1"
                    Text="Number"
                    FontAttributes="Bold"
                    TextColor="#19b5ea"/>

                            <Label
                    Grid.Column="2"
                    Text="Expiry"
                    FontAttributes="Bold"
                    TextColor="#19b5ea"/>

                        </Grid>

                        <!-- ROW -->

                        <Grid
                ColumnDefinitions="3*,2*,2*"
                Padding="0,2">

                            <Label
                    Text="COC Master"
                    TextColor="White"/>

                            <Label
                    Grid.Column="1"
                    Text="12345"
                    TextColor="White"/>

                            <Label
                    Grid.Column="2"
                    Text="2029"
                    TextColor="#00d4ff"/>

                        </Grid>

                    </VerticalStackLayout>

                </Border>

                <!-- CERTIFICATES -->

                <Border
        BackgroundColor="#102844"
        Stroke="#173b63"
        StrokeShape="RoundRectangle 10"
        Padding="8">

                    <VerticalStackLayout
            Spacing="6">

                        <Label
                Text="📜 CERTIFICATES"
                FontSize="16"
                FontAttributes="Bold"
                TextColor="#ff8c42"/>

                        <!-- TABLE HEADER -->

                        <Grid
                ColumnDefinitions="3*,2*,2*"
                Padding="0,0,0,4">

                            <Label
                    Text="Certificate"
                    FontAttributes="Bold"
                    TextColor="#19b5ea"/>

                            <Label
                    Grid.Column="1"
                    Text="Country"
                    FontAttributes="Bold"
                    TextColor="#19b5ea"/>

                            <Label
                    Grid.Column="2"
                    Text="Expiry"
                    FontAttributes="Bold"
                    TextColor="#19b5ea"/>

                        </Grid>

                        <!-- ROWS -->

                        <Grid
                ColumnDefinitions="3*,2*,2*"
                Padding="0,2">

                            <Label
                    Text="Advanced Fire Fighting"
                    TextColor="White"/>

                            <Label
                    Grid.Column="1"
                    Text="UK"
                    TextColor="White"/>

                            <Label
                    Grid.Column="2"
                    Text="2028"
                    TextColor="#00d4ff"/>

                        </Grid>

                        <Grid
                ColumnDefinitions="3*,2*,2*"
                Padding="0,2">

                            <Label
                    Text="Medical Care"
                    TextColor="White"/>

                            <Label
                    Grid.Column="1"
                    Text="NO"
                    TextColor="White"/>

                            <Label
                    Grid.Column="2"
                    Text="2027"
                    TextColor="#00d4ff"/>

                        </Grid>

                    </VerticalStackLayout>

                </Border>

                <!-- EXPERIENCE -->

                <Border
        BackgroundColor="#102844"
        Stroke="#173b63"
        StrokeShape="RoundRectangle 10"
        Padding="8">

                    <VerticalStackLayout
            Spacing="6">

                        <Label
                Text="⚙ EXPERIENCE"
                FontSize="16"
                FontAttributes="Bold"
                TextColor="#ff8c42"/>

                        <!-- HEADER -->

                        <Grid
                ColumnDefinitions="2*,2*,2*,2*"
                Padding="0,0,0,4">

                            <Label
                    Text="Vessel"
                    FontAttributes="Bold"
                    TextColor="#19b5ea"/>

                            <Label
                    Grid.Column="1"
                    Text="Rank"
                    FontAttributes="Bold"
                    TextColor="#19b5ea"/>

                            <Label
                    Grid.Column="2"
                    Text="Company"
                    FontAttributes="Bold"
                    TextColor="#19b5ea"/>

                            <Label
                    Grid.Column="3"
                    Text="Period"
                    FontAttributes="Bold"
                    TextColor="#19b5ea"/>

                        </Grid>

                        <!-- ROW -->

                        <Grid
                ColumnDefinitions="2*,2*,2*,2*"
                Padding="0,2">

                            <Label
                    Text="Bulk Carrier"
                    TextColor="White"/>

                            <Label
                    Grid.Column="1"
                    Text="Chief Officer"
                    TextColor="White"/>

                            <Label
                    Grid.Column="2"
                    Text="V.Group"
                    TextColor="White"/>

                            <Label
                    Grid.Column="3"
                    Text="2023-2025"
                    TextColor="#00d4ff"/>

                        </Grid>

                    </VerticalStackLayout>

                </Border>

            </VerticalStackLayout>

            <!-- ===================================== -->
            <!-- RIGHT COLUMN -->
            <!-- ===================================== -->

            <VerticalStackLayout
    Grid.Column="1"
    Spacing="10">

                <!-- CONTACTS -->

                <Border
        BackgroundColor="#102844"
        Stroke="#173b63"
        StrokeShape="RoundRectangle 10"
        Padding="8">

                    <VerticalStackLayout Spacing="8">

                        <Grid ColumnDefinitions="*,Auto">

                            <Label
                    Text="📞 CONTACTS"
                    FontSize="16"
                    FontAttributes="Bold"
                    TextColor="#ff8c42"/>

                            <Button
                    Grid.Column="1"
                    Text="Edit"
                    WidthRequest="70"
                    HeightRequest="30"
                    CornerRadius="6"
                    FontSize="12"
                    BackgroundColor="#19b5ea"
                    TextColor="White"
                    Clicked="OnEditContactsClicked"/>

                        </Grid>

                        <VerticalStackLayout
                x:Name="ContactsPreviewContainer"
                Spacing="6"/>

                    </VerticalStackLayout>

                </Border>

                <!-- SKILLS & LANGUAGES -->

                <Border
        BackgroundColor="#102844"
        Stroke="#173b63"
        StrokeShape="RoundRectangle 10"
        Padding="8">

                    <VerticalStackLayout Spacing="6">

                        <Label
                Text="🌍 SKILLS &amp; LANGUAGES"
                FontSize="16"
                FontAttributes="Bold"
                TextColor="#ff8c42"/>

                        <Entry
                Placeholder="English Level"
                HeightRequest="30"
                BackgroundColor="#1a2238"
                TextColor="White"/>

                        <Entry
                Placeholder="Marlins Test"
                HeightRequest="30"
                BackgroundColor="#1a2238"
                TextColor="White"/>

                    </VerticalStackLayout>

                </Border>

                <!-- VISA -->

                <Border
    BackgroundColor="#102844"
    Stroke="#173b63"
    StrokeShape="RoundRectangle 10"
    Padding="8">

                    <VerticalStackLayout Spacing="6">

                        <Grid ColumnDefinitions="*,Auto">

                            <Label
        Text="🛂 VISA"
        FontSize="16"
        FontAttributes="Bold"
        TextColor="#ff8c42"
        VerticalOptions="Center"/>

                            <Button
        Grid.Column="1"
        Text="Edit"
        Clicked="OnEditVisaClicked"
        HeightRequest="28"
        WidthRequest="55"
        FontSize="12"
        BackgroundColor="#19b5ea"
        TextColor="White"/>

        </Grid>

        <!-- Заголовок таблицы -->

                        <Grid ColumnDefinitions="*,*,Auto">

                            <Label
                Text="Type"
                FontAttributes="Bold"
                TextColor="#8ea9c7"/>

                            <Label
                Grid.Column="1"
                Text="Country"
                FontAttributes="Bold"
                TextColor="#8ea9c7"/>

                            <Label
                Grid.Column="2"
                Text="Expiry"
                FontAttributes="Bold"
                TextColor="#8ea9c7"/>

                        </Grid>

                        <!-- Сюда будут подгружаться визы -->

                        <VerticalStackLayout
            x:Name="VisaPreviewContainer"
            Spacing="4"/>

                    </VerticalStackLayout>

                </Border>
                <!-- BIOMETRIC -->

                <Border
    BackgroundColor="#102844"
    Stroke="#173b63"
    StrokeShape="RoundRectangle 10"
    Padding="8">

                    <VerticalStackLayout Spacing="6">

                        <Label
            Text="🧬 BIOMETRIC"
            FontSize="16"
            FontAttributes="Bold"
            TextColor="#ff8c42"/>

                        <Grid
            ColumnDefinitions="*,*"
            RowDefinitions="Auto,Auto,Auto"
            ColumnSpacing="10"
            RowSpacing="4">

                            <!-- Height -->

                            <VerticalStackLayout
                Grid.Row="0"
                Grid.Column="0"
                Spacing="2">

                                <Label
                    Text="Height"
                    FontSize="12"
                    TextColor="White"/>

                                <Entry
                    x:Name="HeightEntry"
                    HeightRequest="30"
                    FontSize="16"/>
                            </VerticalStackLayout>

                            <!-- Weight -->

                            <VerticalStackLayout
                Grid.Row="0"
                Grid.Column="1"
                Spacing="2">

                                <Label
                    Text="Weight"
                    FontSize="12"
                    TextColor="White"/>

                                <Entry
                    x:Name="WeightEntry"
                    HeightRequest="30"
                    FontSize="16"/>
                            </VerticalStackLayout>

                            <!-- Shoe Size -->

                            <VerticalStackLayout
                Grid.Row="1"
                Grid.Column="0"
                Spacing="2">

                                <Label
                    Text="Shoe Size"
                    FontSize="12"
                    TextColor="White"/>

                                <Entry
                    x:Name="ShoeSizeEntry"
                    HeightRequest="30"
                    FontSize="16"/>
                            </VerticalStackLayout>

                            <!-- Overall Size -->

                            <VerticalStackLayout
                Grid.Row="1"
                Grid.Column="1"
                Spacing="2">

                                <Label
                    Text="Overall Size"
                    FontSize="12"
                    TextColor="White"/>

                                <Entry
                    x:Name="OverallSizeEntry"
                    HeightRequest="30"
                    FontSize="16"/>
                            </VerticalStackLayout>

                            <!-- Hair Color -->

                            <VerticalStackLayout
                Grid.Row="2"
                Grid.Column="0"
                Spacing="2">

                                <Label
                    Text="Hair Color"
                    FontSize="12"
                    TextColor="White"/>

                                <Entry
                    x:Name="HairColorEntry"
                    HeightRequest="30"
                    FontSize="16"/>
                            </VerticalStackLayout>

                            <!-- Eye Color -->

                            <VerticalStackLayout
                Grid.Row="2"
                Grid.Column="1"
                Spacing="2">

                                <Label
                    Text="Eye Color"
                    FontSize="12"
                    TextColor="White"/>

                                <Entry
                    x:Name="EyeColorEntry"
                    HeightRequest="30"
                    FontSize="16"/>
                            </VerticalStackLayout>

                        </Grid>

                    </VerticalStackLayout>

                </Border>
                <!-- NEXT OF KIN -->

                <Border
    BackgroundColor="#102844"
    Stroke="#173b63"
    StrokeShape="RoundRectangle 10"
    Padding="8">

                    <VerticalStackLayout Spacing="4">

                        <Label
            Text="👨‍👩‍👧 NEXT OF KIN"
            FontSize="16"
            FontAttributes="Bold"
            TextColor="#ff8c42"/>

                        <Label
            Text="Full Name"
            FontSize="12"
            TextColor="White"/>

                        <Entry
            x:Name="KinNameEntry"
            HeightRequest="30"
            FontSize="16"/>

                        <Label
            Text="Relation"
            FontSize="12"
            TextColor="White"/>

                        <Entry
            x:Name="KinRelationEntry"
            HeightRequest="30"
            FontSize="16"/>

                        <Label
            Text="Phone"
            FontSize="12"
            TextColor="White"/>

                        <Entry
            x:Name="KinPhoneEntry"
            HeightRequest="30"
            FontSize="16"/>

                        <Label
            Text="Email"
            FontSize="12"
            TextColor="White"/>

                        <Entry
            x:Name="KinEmailEntry"
            HeightRequest="30"
            FontSize="16"/>

                        <Label
            Text="Address"
            FontSize="12"
            TextColor="White"/>

                        <Editor
            x:Name="KinAddressEditor"
            HeightRequest="60"
            FontSize="16"/>

                    </VerticalStackLayout>

                </Border>
            </VerticalStackLayout>
        </Grid>

    </ScrollView>

</ContentView>