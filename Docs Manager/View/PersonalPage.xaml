<?xml version="1.0" encoding="utf-8" ?>

<ContentView
    x:Class="Docs_Manager.View.PersonalPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    BackgroundColor="#071a2f">

    <ScrollView>

        <Grid
            Padding="16"
            ColumnSpacing="16"
            RowSpacing="16">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- ========================================= -->
            <!-- LEFT COLUMN -->
            <!-- ========================================= -->

            <VerticalStackLayout
                Grid.Column="0"
                Spacing="16">

                <!-- CAREER PREFERENCES -->

                <Border
    BackgroundColor="#102844"
    Stroke="#173b63"
    StrokeShape="RoundRectangle 14"
    Padding="14">

                    <VerticalStackLayout Spacing="12">

                        <Label
            Text="⚓ CAREER PREFERENCES"
            FontSize="22"
            FontAttributes="Bold"
            TextColor="#00d4ff"/>

                        <!-- DESIRED RANK -->

                        <Entry
            x:Name="DesiredRankEntry"
            HeightRequest="42"
            Placeholder="Desired Position / Rank"
            BackgroundColor="#1a2238"
            TextColor="White"
            PlaceholderColor="#7a8999"/>

                        <!-- VESSEL TYPES -->

                        <Label
            Text="Desired Vessel Types"
            FontSize="12"
            TextColor="#7a8999"/>

                        <Grid
            ColumnDefinitions="*,*"
            RowDefinitions="Auto,Auto,Auto"
            ColumnSpacing="10"
            RowSpacing="8">

                            <HorizontalStackLayout
                Grid.Row="0"
                Grid.Column="0"
                Spacing="6">

                                <CheckBox x:Name="BulkCarrierCheckBox"/>

                                <Label
                    Text="Bulk Carrier"
                    TextColor="White"
                    VerticalOptions="Center"/>

                            </HorizontalStackLayout>

                            <HorizontalStackLayout
                Grid.Row="0"
                Grid.Column="1"
                Spacing="6">

                                <CheckBox x:Name="ContainerCheckBox"/>

                                <Label
                    Text="Container"
                    TextColor="White"
                    VerticalOptions="Center"/>

                            </HorizontalStackLayout>

                            <HorizontalStackLayout
                Grid.Row="1"
                Grid.Column="0"
                Spacing="6">

                                <CheckBox x:Name="TankerVesselCheckBox"/>

                                <Label
                    Text="Tanker"
                    TextColor="White"
                    VerticalOptions="Center"/>

                            </HorizontalStackLayout>

                            <HorizontalStackLayout
                Grid.Row="1"
                Grid.Column="1"
                Spacing="6">

                                <CheckBox x:Name="OffshoreCheckBox"/>

                                <Label
                    Text="Offshore"
                    TextColor="White"
                    VerticalOptions="Center"/>

                            </HorizontalStackLayout>

                            <HorizontalStackLayout
                Grid.Row="2"
                Grid.Column="0"
                Spacing="6">

                                <CheckBox x:Name="RoRoCheckBox"/>

                                <Label
                    Text="Ro-Ro"
                    TextColor="White"
                    VerticalOptions="Center"/>

                            </HorizontalStackLayout>

                            <HorizontalStackLayout
                Grid.Row="2"
                Grid.Column="1"
                Spacing="6">

                                <CheckBox x:Name="CruiseCheckBox"/>

                                <Label
                    Text="Cruise"
                    TextColor="White"
                    VerticalOptions="Center"/>

                            </HorizontalStackLayout>

                        </Grid>

                    </VerticalStackLayout>

                </Border>
                <!-- BASIC INFORMATION -->

                <Border
                    BackgroundColor="#102844"
                    Stroke="#173b63"
                    StrokeShape="RoundRectangle 14"
                    Padding="14">

                    <VerticalStackLayout Spacing="10">

                        <Label
                            Text="📋 BASIC INFORMATION"
                            FontSize="18"
                            FontAttributes="Bold"
                            TextColor="#ff8c42"/>

                        <Entry
                            x:Name="FirstNameEntry"
                            HeightRequest="42"
                            Placeholder="First Name"
                            BackgroundColor="#1a2238"
                            TextColor="White"
                            PlaceholderColor="#7a8999"/>

                        <Entry
                            x:Name="LastNameEntry"
                            HeightRequest="42"
                            Placeholder="Last Name"
                            BackgroundColor="#1a2238"
                            TextColor="White"
                            PlaceholderColor="#7a8999"/>

                        <Grid
                            ColumnDefinitions="160,180,*"
                            ColumnSpacing="16">

                            <!-- DATE -->

                            <VerticalStackLayout
                                Grid.Column="0"
                                Spacing="4">

                                <Label
                                    Text="Date of birth"
                                    FontSize="11"
                                    TextColor="#7a8999"/>

                                <DatePicker
                                    x:Name="BirthDatePicker"
                                    HeightRequest="42"
                                    BackgroundColor="Transparent"
                                    TextColor="White"/>

                            </VerticalStackLayout>

                            <!-- GENDER -->

                            <VerticalStackLayout
                                Grid.Column="1"
                                Spacing="4">

                                <Label
                                    Text="Gender"
                                    FontSize="11"
                                    TextColor="#7a8999"/>

                                <Picker
                                    x:Name="GenderPicker"
                                    BackgroundColor="Transparent"
                                    TextColor="White">

                                    <Picker.Items>
                                        <x:String>Male</x:String>
                                        <x:String>Female</x:String>
                                    </Picker.Items>

                                </Picker>

                            </VerticalStackLayout>

                            <!-- CITIZENSHIP -->

                            <VerticalStackLayout
                                Grid.Column="2"
                                Spacing="4">

                                <Label
                                    Text="Citizenship"
                                    FontSize="11"
                                    TextColor="#7a8999"/>

                                <Entry
                                    x:Name="CitizenshipEntry"
                                    HeightRequest="42"
                                    Placeholder="Citizenship"
                                    BackgroundColor="Transparent"
                                    TextColor="White"
                                    PlaceholderColor="#7a8999"/>

                            </VerticalStackLayout>

                        </Grid>

                    </VerticalStackLayout>

                </Border>

                <!-- CONTACTS -->

                <Border
                    BackgroundColor="#102844"
                    Stroke="#173b63"
                    StrokeShape="RoundRectangle 14"
                    Padding="14">

                    <VerticalStackLayout Spacing="12">

                        <Grid ColumnDefinitions="*,Auto">

                            <Label
                                Text="📞 CONTACTS"
                                FontSize="18"
                                FontAttributes="Bold"
                                TextColor="#ff8c42"/>

                            <Button
                                Grid.Column="1"
                                Text="Edit"
                                HeightRequest="36"
                                WidthRequest="70"
                                CornerRadius="10"
                                BackgroundColor="#19b5ea"
                                TextColor="White"
                                FontAttributes="Bold"
                                Clicked="OnEditContactsClicked"/>

                        </Grid>

                        <!-- CONTACTS PREVIEW -->

                        <VerticalStackLayout
                            x:Name="ContactsPreviewContainer"
                            Spacing="10"/>

                    </VerticalStackLayout>

                </Border>

                <!-- EDUCATION -->

                <Border
                    BackgroundColor="#102844"
                    Stroke="#173b63"
                    StrokeShape="RoundRectangle 14"
                    Padding="14">

                    <VerticalStackLayout Spacing="12">

                        <Grid ColumnDefinitions="*,Auto">

                            <Label
                                Text="🎓 EDUCATION"
                                FontSize="18"
                                FontAttributes="Bold"
                                TextColor="#ff8c42"/>

                            <Button
                                Grid.Column="1"
                                Text="Edit"
                                HeightRequest="36"
                                WidthRequest="70"
                                CornerRadius="10"
                                BackgroundColor="#19b5ea"
                                TextColor="White"
                                FontAttributes="Bold"
                                Clicked="OnEditEducationClicked"/>

                        </Grid>

                        <!-- EDUCATION PREVIEW -->

                        <VerticalStackLayout
                            x:Name="EducationPreviewContainer"
                            Spacing="10"/>

                    </VerticalStackLayout>

                </Border>


                <!-- ADDRESS -->

                <Border
                    BackgroundColor="#102844"
                    Stroke="#173b63"
                    StrokeShape="RoundRectangle 14"
                    Padding="14">

                    <VerticalStackLayout Spacing="10">

                        <Label
                            Text="📍 ADDRESS"
                            FontSize="18"
                            FontAttributes="Bold"
                            TextColor="#ff8c42"/>

                        <Entry
                            x:Name="ResidenceEntry"
                            HeightRequest="42"
                            Placeholder="Residence"
                            BackgroundColor="#1a2238"
                            TextColor="White"
                            PlaceholderColor="#7a8999"/>

                        <Entry
                            x:Name="ResidenceAirportEntry"
                            HeightRequest="42"
                            Placeholder="Nearest Airport"
                            BackgroundColor="#1a2238"
                            TextColor="White"
                            PlaceholderColor="#7a8999"/>

                    </VerticalStackLayout>

                </Border>

            </VerticalStackLayout>

            <!-- ========================================= -->
            <!-- RIGHT COLUMN -->
            <!-- ========================================= -->

            <VerticalStackLayout
                Grid.Column="1"
                Spacing="16">

                <!-- SAVE -->

                <Button
                    x:Name="SaveButton"
                    Text="💾 Save Profile"
                    HeightRequest="42"
                    CornerRadius="10"
                    BackgroundColor="#28a745"
                    TextColor="White"
                    FontAttributes="Bold"
                    Clicked="OnSaveClicked"/>

                <!-- PHOTO -->

                <Border
                    BackgroundColor="#102844"
                    Stroke="#173b63"
                    StrokeShape="RoundRectangle 14"
                    Padding="14">

                    <VerticalStackLayout
                        Spacing="14"
                        HorizontalOptions="Center">

                        <Label
                            Text="📸 PHOTO"
                            FontSize="18"
                            FontAttributes="Bold"
                            TextColor="#ff8c42"/>

                        <Frame
                            WidthRequest="180"
                            HeightRequest="220"
                            Padding="0"
                            CornerRadius="12"
                            BackgroundColor="#1a2238"
                            HasShadow="False"
                            BorderColor="#2d4d73">

                            <Image
                                x:Name="PhotoImage"
                                Aspect="AspectFill"/>

                        </Frame>

                        <Button
                            x:Name="PickPhotoButton"
                            Text="Choose Photo"
                            WidthRequest="180"
                            HeightRequest="40"
                            CornerRadius="10"
                            BackgroundColor="#19b5ea"
                            TextColor="White"
                            FontAttributes="Bold"
                            Clicked="OnPickPhotoClicked"/>

                    </VerticalStackLayout>

                </Border>

                <!-- BIOMETRIC -->

                <Border
    BackgroundColor="#102844"
    Stroke="#173b63"
    StrokeShape="RoundRectangle 14"
    Padding="14">

                    <VerticalStackLayout Spacing="10">

                        <Label
            Text="🧬 BIOMETRIC"
            FontSize="18"
            FontAttributes="Bold"
            TextColor="#ff8c42"/>

                        <!-- HEIGHT / WEIGHT -->

                        <Grid
            ColumnDefinitions="*,*"
            ColumnSpacing="10">

                            <Entry
                Grid.Column="0"
                x:Name="HeightEntry"
                HeightRequest="42"
                Placeholder="Height"
                Keyboard="Numeric"
                BackgroundColor="#1a2238"
                TextColor="White"
                PlaceholderColor="#7a8999"/>

                            <Entry
                Grid.Column="1"
                x:Name="WeightEntry"
                HeightRequest="42"
                Placeholder="Weight"
                Keyboard="Numeric"
                BackgroundColor="#1a2238"
                TextColor="White"
                PlaceholderColor="#7a8999"/>

                        </Grid>

                        <!-- SHOE / OVERALL -->

                        <Grid
            ColumnDefinitions="*,*"
            ColumnSpacing="10">

                            <Entry
                Grid.Column="0"
                x:Name="ShoeSizeEntry"
                HeightRequest="42"
                Placeholder="Shoe Size"
                Keyboard="Numeric"
                BackgroundColor="#1a2238"
                TextColor="White"
                PlaceholderColor="#7a8999"/>

                            <Entry
                Grid.Column="1"
                x:Name="OverallSizeEntry"
                HeightRequest="42"
                Placeholder="Overall Size"
                Keyboard="Numeric"
                BackgroundColor="#1a2238"
                TextColor="White"
                PlaceholderColor="#7a8999"/>

                        </Grid>

                        <!-- HAIR -->

                        <Entry
            x:Name="HairColorEntry"
            HeightRequest="42"
            Placeholder="Hair Color"
            BackgroundColor="#1a2238"
            TextColor="White"
            PlaceholderColor="#7a8999"/>

                        <!-- EYES -->

                        <Entry
            x:Name="EyeColorEntry"
            HeightRequest="42"
            Placeholder="Eye Color"
            BackgroundColor="#1a2238"
            TextColor="White"
            PlaceholderColor="#7a8999"/>

                    </VerticalStackLayout>

                </Border>

                <!-- NEXT OF KIN -->

                <Border
    BackgroundColor="#102844"
    Stroke="#173b63"
    StrokeShape="RoundRectangle 14"
    Padding="14">

                    <VerticalStackLayout Spacing="10">

                        <Label
            Text="👨‍👩‍👧 NEXT OF KIN"
            FontSize="18"
            FontAttributes="Bold"
            TextColor="#ff8c42"/>

                        <Entry
            x:Name="KinNameEntry"
            HeightRequest="42"
            Placeholder="Full Name"
            BackgroundColor="#1a2238"
            TextColor="White"
            PlaceholderColor="#7a8999"/>

                        <Entry
            x:Name="KinRelationEntry"
            HeightRequest="42"
            Placeholder="Relation"
            BackgroundColor="#1a2238"
            TextColor="White"
            PlaceholderColor="#7a8999"/>

                        <Entry
            x:Name="KinPhoneEntry"
            HeightRequest="42"
            Placeholder="Phone Number"
            Keyboard="Telephone"
            BackgroundColor="#1a2238"
            TextColor="White"
            PlaceholderColor="#7a8999"/>

                        <Entry
            x:Name="KinEmailEntry"
            HeightRequest="42"
            Placeholder="Email"
            Keyboard="Email"
            BackgroundColor="#1a2238"
            TextColor="White"
            PlaceholderColor="#7a8999"/>

                        <Editor
            x:Name="KinAddressEditor"
            HeightRequest="80"
            Placeholder="Address"
            BackgroundColor="#1a2238"
            TextColor="White"
            PlaceholderColor="#7a8999"/>

                    </VerticalStackLayout>

                </Border>


            </VerticalStackLayout>

        </Grid>

    </ScrollView>

</ContentView>