<?xml version="1.0" encoding="utf-8" ?>

<ContentView
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="Docs_Manager.View.PersonalPage"
    BackgroundColor="#0a1628">

    <ScrollView>

        <VerticalStackLayout
            Padding="25"
            Spacing="20">

            <Label
                Text="Personal Information"
                FontSize="22"
                FontAttributes="Bold"
                TextColor="#00d4ff"/>

            <!-- FIRST NAME -->
            <VerticalStackLayout Spacing="5">

                <Label
                    Text="First Name"
                    TextColor="#7a8999"
                    FontSize="12"/>

                <Entry
                    x:Name="FirstNameEntry"
                    Placeholder="Enter first name"
                    TextColor="White"
                    PlaceholderColor="#7a8999"
                    BackgroundColor="#112033"/>

            </VerticalStackLayout>

            <!-- LAST NAME -->
            <VerticalStackLayout Spacing="5">

                <Label
                    Text="Last Name"
                    TextColor="#7a8999"
                    FontSize="12"/>

                <Entry
                    x:Name="LastNameEntry"
                    Placeholder="Enter last name"
                    TextColor="White"
                    PlaceholderColor="#7a8999"
                    BackgroundColor="#112033"/>

            </VerticalStackLayout>

            <!-- DATE -->
            <VerticalStackLayout Spacing="5">

                <Label
                    Text="Birth Date"
                    TextColor="#7a8999"
                    FontSize="12"/>

                <DatePicker
                    x:Name="BirthDatePicker"
                    TextColor="White"
                    BackgroundColor="#112033"/>

            </VerticalStackLayout>

            <!-- SAVE -->
            <Button
                Text="Save Profile"
                HeightRequest="50"
                BackgroundColor="#00a86b"
                TextColor="White"
                Clicked="OnSaveClicked"/>

        </VerticalStackLayout>

    </ScrollView>

</ContentView>