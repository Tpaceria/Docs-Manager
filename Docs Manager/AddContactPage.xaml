<?xml version="1.0" encoding="utf-8" ?>

<ContentPage
    x:Class="Docs_Manager.View.AddContactPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    BackgroundColor="#071a2f"
    Title="Contacts">

    <ScrollView>

        <VerticalStackLayout
            Padding="20"
            Spacing="16">

            <Grid ColumnDefinitions="*,Auto">

                <Label
                    Text="📞 Contacts"
                    FontSize="24"
                    FontAttributes="Bold"
                    TextColor="#00d4ff"/>

                <Button
                    Grid.Column="1"
                    Text="✕"
                    WidthRequest="40"
                    HeightRequest="40"
                    CornerRadius="20"
                    BackgroundColor="#ff4d6d"
                    TextColor="White"
                    Clicked="OnCloseClicked"/>

            </Grid>

            <!-- PHONE -->

            <Border
                BackgroundColor="#102844"
                Stroke="#173b63"
                StrokeShape="RoundRectangle 12"
                Padding="14">

                <VerticalStackLayout Spacing="12">

                    <Grid ColumnDefinitions="*,Auto">

                        <Label
                            Text="Phone Numbers"
                            FontSize="16"
                            FontAttributes="Bold"
                            TextColor="White"/>

                        <Button
                            Grid.Column="1"
                            Text="+"
                            WidthRequest="34"
                            HeightRequest="34"
                            CornerRadius="17"
                            BackgroundColor="#19b5ea"
                            TextColor="White"
                            Clicked="OnAddPhoneClicked"/>

                    </Grid>

                    <VerticalStackLayout
                        x:Name="PhoneContainer"
                        Spacing="10"/>

                </VerticalStackLayout>

            </Border>

            <!-- EMAIL -->

            <Border
                BackgroundColor="#102844"
                Stroke="#173b63"
                StrokeShape="RoundRectangle 12"
                Padding="14">

                <VerticalStackLayout Spacing="12">

                    <Grid ColumnDefinitions="*,Auto">

                        <Label
                            Text="Email Addresses"
                            FontSize="16"
                            FontAttributes="Bold"
                            TextColor="White"/>

                        <Button
                            Grid.Column="1"
                            Text="+"
                            WidthRequest="34"
                            HeightRequest="34"
                            CornerRadius="17"
                            BackgroundColor="#19b5ea"
                            TextColor="White"
                            Clicked="OnAddEmailClicked"/>

                    </Grid>

                    <VerticalStackLayout
                        x:Name="EmailContainer"
                        Spacing="10"/>

                </VerticalStackLayout>

            </Border>

            <!-- SAVE -->

            <Button
                Text="💾 Save Contacts"
                HeightRequest="48"
                CornerRadius="10"
                BackgroundColor="#28a745"
                TextColor="White"
                FontAttributes="Bold"
                Clicked="OnSaveClicked"/>

        </VerticalStackLayout>

    </ScrollView>

</ContentPage>