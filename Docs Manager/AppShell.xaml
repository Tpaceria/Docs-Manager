<Shell
    x:Class="Docs_Manager.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:Docs_Manager.View"
    Shell.FlyoutBehavior="Flyout">

    <FlyoutItem Title="Profile">
        <ShellContent Title="Personal Data"
                      ContentTemplate="{DataTemplate views:PersonalPage}" />
    </FlyoutItem>

    <FlyoutItem Title="Files">
        <ShellContent Title="My Files"
                      ContentTemplate="{DataTemplate views:FilesPage}" />
    </FlyoutItem>

    <FlyoutItem Title="Experience">
        <ShellContent Title="Experience Data"
                      ContentTemplate="{DataTemplate views:ExperiencePage}" />
    </FlyoutItem>

</Shell>